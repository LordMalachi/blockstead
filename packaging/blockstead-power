#!/usr/bin/env bash
set -euo pipefail
[[ ${1:-} == poweroff ]] || { echo "unsupported power action" >&2; exit 2; }
if [[ ${2:-} == --wake ]]; then
  [[ ${3:-} =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}$ ]] || exit 2
  /usr/sbin/rtcwake -m no -t "$(/usr/bin/date -d "$3" +%s)"
fi
/usr/bin/systemctl poweroff
