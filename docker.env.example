# Copy this file to docker.env and pass it with:
# docker compose --env-file docker.env up --build -d

# Dashboard access stays on this computer by default.
BLOCKSTEAD_DASHBOARD_BIND=127.0.0.1
BLOCKSTEAD_DASHBOARD_PORT=8765

# Minecraft is reachable on the local network by default.
MINECRAFT_BIND=0.0.0.0
MINECRAFT_PORT=25565

# If exposing the dashboard on your LAN, add its exact browser URL here, for example:
# BLOCKSTEAD_ALLOWED_ORIGINS=http://192.168.1.25:8765
BLOCKSTEAD_ALLOWED_ORIGINS=http://127.0.0.1:8765,http://localhost:8765

# Keep false for ordinary local HTTP. Set true only when the dashboard is behind HTTPS.
BLOCKSTEAD_SECURE_COOKIES=false

